{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-notifications",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cleanup-archive",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron-assignments",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron-daily-digest",
      "schedule": "30 2 * * *"
    }
  ]
}
